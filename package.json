{
  "name": "auto-media-converter",
  "version": "1.0.1",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "description": "Automatizador de conversiones AVIF/WebP",
  "author": {
    "name": "Tony",
    "email": "franco.ncarballes@gmail.com"
  },
  "files": [
    "main.js",
    "preload.cjs",
    "renderer.js",
    "index.html",
    "assets/**/*",
    "package.json"
  ],
  "homepage": "https://github.com/FNCarballes",
  "build": {
    "appId": "f.n.c.automediaconverter",
    "productName": "Auto Media Converter",
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "**/node_modules/sharp/**/*",
      "**/node_modules/@img/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "executableName": "auto-media-converter"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.png"
    }
  },
  "keywords": [],
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "auto-launch": "^5.0.6",
    "chokidar": "^5.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3"
  }
}
